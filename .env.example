# Copy this file to `.env` and edit to suit your deployment.

# Required: OxiCloud reachable from the proxy.
# Use the Docker service name on a shared network, or a LAN host:port.
OXICLOUD_INTERNAL_URL=http://oxicloud:8086

# Required: public-facing URL the proxy is served from.
PUBLIC_BASE_URL=https://files.example.com

# Optional: TCP port (default 3000). Used for both the host port mapping
# and the in-container listen port - they must match.
# PORT=3000

# Optional: bind address (default 0.0.0.0).
# HOST=0.0.0.0

# Optional: pino log level (fatal, error, warn, info, debug, trace).
# LOG_LEVEL=info
