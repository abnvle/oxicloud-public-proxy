{
  "name": "oxicloud-public-proxy",
  "version": "1.0.0",
  "description": "Public reverse proxy for OxiCloud share links - exposes shares on a public domain while keeping OxiCloud private.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^8.3.0",
    "@fastify/view": "^11.0.0",
    "ejs": "^3.1.10",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.10.7",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
