<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OxiCloud</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Michroma&family=Outfit:wght@400;600;700&display=swap"
    rel="stylesheet"
  />
  <style>
    :root {
      color-scheme: light dark;
      --fg: #1a1a1a;
      --fg-muted: #6b7280;
      --bg-grad-start: #ffe4d4;
      --bg-grad-end: #fef5f0;
      --accent: #f0664a;
      --link: #1a1a1a;
      --link-hover: #f0664a;
      --chip-bg: rgba(255, 255, 255, 0.6);
      --chip-border: rgba(0, 0, 0, 0.06);
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --fg: #f3f4f6;
        --fg-muted: #94a3b8;
        --bg-grad-start: #1a1024;
        --bg-grad-end: #0a0814;
        --link: #f3f4f6;
        --link-hover: #ff8463;
        --chip-bg: rgba(255, 255, 255, 0.06);
        --chip-border: rgba(255, 255, 255, 0.1);
      }
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: "Outfit", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: radial-gradient(
        ellipse at top,
        var(--bg-grad-start) 0%,
        var(--bg-grad-end) 70%
      );
      color: var(--fg);
      display: grid;
      grid-template-rows: 1fr auto;
      min-height: 100%;
      padding: 24px;
    }

    main {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 32px;
      animation: rise 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    @keyframes rise {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .brand {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }
    .logo {
      width: 220px;
      height: auto;
      display: block;
      filter: drop-shadow(0 24px 40px rgba(240, 102, 74, 0.25));
    }
    @media (prefers-color-scheme: dark) {
      .logo { filter: drop-shadow(0 24px 40px rgba(0, 0, 0, 0.6)); }
    }

    .tagline {
      font-family: "Michroma", sans-serif;
      font-size: 14px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #ff684b;
      margin: 0;
    }

    .repo-link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 11px 20px;
      border-radius: 999px;
      background: var(--chip-bg);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid var(--chip-border);
      color: var(--link);
      text-decoration: none;
      font-weight: 600;
      font-size: 15px;
      transition: color 160ms ease, transform 160ms ease;
    }
    .repo-link:hover {
      color: var(--link-hover);
      transform: translateY(-1px);
    }
    .repo-link svg {
      width: 18px;
      height: 18px;
      flex: none;
    }
    .repo-link .arrow {
      transition: transform 160ms ease;
    }
    .repo-link:hover .arrow {
      transform: translateX(2px);
    }

    footer {
      text-align: center;
      color: var(--fg-muted);
      font-size: 13px;
      letter-spacing: 0.04em;
      padding-top: 24px;
    }
    footer .sep {
      display: inline-block;
      margin: 0 6px;
      opacity: 0.6;
    }
    footer strong {
      color: var(--fg);
      font-weight: 700;
      letter-spacing: 0;
    }
  </style>
</head>
<body>
  <main>
    <div class="brand">
      <img class="logo" src="/public/oxicloud-logo.png" alt="OxiCloud" />
      <p class="tagline">public proxy</p>
    </div>

    <a
      class="repo-link"
      href="https://github.com/abnvle/oxicloud-public-proxy"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.27-1.7-1.27-1.7-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.17a10.95 10.95 0 015.74 0c2.18-1.48 3.14-1.17 3.14-1.17.62 1.59.23 2.76.11 3.05.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
      </svg>
      <span>View on GitHub</span>
      <span class="arrow" aria-hidden="true">→</span>
    </a>
  </main>

  <footer>
    <strong>OxiCloud</strong>
    <span class="sep">·</span>
    secure file sharing
  </footer>
</body>
</html>
