<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <% if (state === 'file' || state === 'folder') { %>
      <%= itemName %>
    <% } else if (state === 'password') { %>
      <%= t('page.title.password') %>
    <% } else if (state === 'expired') { %>
      <%= t('page.title.expired') %>
    <% } else { %>
      <%= t('page.title.error') %>
    <% } %>
  </title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <style>
    :root {
      color-scheme: light dark;
      --fg: #1a1a1a;
      --fg-muted: #6b7280;
      --bg-grad-start: #ffe4d4;
      --bg-grad-end: #fef5f0;
      --card-bg: rgba(255, 255, 255, 0.72);
      --card-border: rgba(0, 0, 0, 0.06);
      --card-shadow: rgba(15, 23, 42, 0.10);
      --accent: #f0664a;
      --accent-strong: #ff684b;
      --accent-fg: #ffffff;
      --accent-soft: rgba(240, 102, 74, 0.12);
      --accent-glow: rgba(240, 102, 74, 0.30);
      --input-bg: rgba(255, 255, 255, 0.85);
      --input-border: rgba(0, 0, 0, 0.08);
      --input-ring: rgba(240, 102, 74, 0.18);
      --error-bg: rgba(220, 38, 38, 0.08);
      --error-fg: #b91c1c;
      --hover-tint: rgba(0, 0, 0, 0.04);
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --fg: #f3f4f6;
        --fg-muted: #94a3b8;
        --bg-grad-start: #1a1024;
        --bg-grad-end: #0a0814;
        --card-bg: rgba(30, 41, 59, 0.55);
        --card-border: rgba(255, 255, 255, 0.08);
        --card-shadow: rgba(0, 0, 0, 0.45);
        --accent-soft: rgba(240, 102, 74, 0.18);
        --input-bg: rgba(15, 23, 42, 0.55);
        --input-border: rgba(255, 255, 255, 0.10);
        --error-bg: rgba(220, 38, 38, 0.18);
        --error-fg: #fca5a5;
        --hover-tint: rgba(255, 255, 255, 0.06);
      }
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: "Outfit", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: radial-gradient(
        ellipse at top,
        var(--bg-grad-start) 0%,
        var(--bg-grad-end) 70%
      );
      color: var(--fg);
      display: grid;
      place-items: center;
      padding: 24px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    main {
      width: 100%;
      max-width: 440px;
      animation: rise 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    @keyframes rise {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .card {
      background: var(--card-bg);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid var(--card-border);
      border-radius: 20px;
      padding: 36px 32px;
      box-shadow: 0 20px 50px var(--card-shadow);
    }

    .icon-tile {
      width: 60px;
      height: 60px;
      border-radius: 16px;
      background: var(--accent-soft);
      color: var(--accent);
      display: grid;
      place-items: center;
      margin: 0 auto 22px;
    }
    .icon-tile svg { width: 28px; height: 28px; }

    h1 {
      font-size: 22px;
      font-weight: 700;
      text-align: center;
      letter-spacing: -0.01em;
      margin-bottom: 8px;
      word-break: break-word;
    }
    .lead {
      text-align: center;
      color: var(--fg-muted);
      font-size: 15px;
      line-height: 1.55;
      margin-bottom: 26px;
    }
    .lead.tight { margin-bottom: 18px; }

    form {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: var(--fg-muted);
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .input-wrap {
      position: relative;
    }
    input[type="password"],
    input[type="text"] {
      width: 100%;
      padding: 14px 50px 14px 16px;
      border: 1px solid var(--input-border);
      border-radius: 12px;
      font-size: 16px;
      font-family: inherit;
      background: var(--input-bg);
      color: var(--fg);
      transition: border-color 160ms ease, box-shadow 160ms ease;
    }
    input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 4px var(--input-ring);
    }
    .toggle-pw {
      position: absolute;
      right: 6px;
      top: 50%;
      transform: translateY(-50%);
      background: transparent;
      border: none;
      width: 38px;
      height: 38px;
      display: grid;
      place-items: center;
      color: var(--fg-muted);
      cursor: pointer;
      border-radius: 8px;
      transition: color 120ms ease, background 120ms ease;
    }
    .toggle-pw:hover { color: var(--fg); background: var(--hover-tint); }
    .toggle-pw svg { width: 18px; height: 18px; }
    .toggle-pw .eye-off { display: none; }
    .toggle-pw[data-shown="true"] .eye-on { display: none; }
    .toggle-pw[data-shown="true"] .eye-off { display: block; }

    .error {
      background: var(--error-bg);
      color: var(--error-fg);
      padding: 11px 14px;
      border-radius: 10px;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .error svg { width: 16px; height: 16px; flex: none; }

    .btn {
      background: var(--accent);
      color: var(--accent-fg);
      padding: 14px 20px;
      border-radius: 12px;
      font-size: 15px;
      font-weight: 600;
      font-family: inherit;
      border: none;
      cursor: pointer;
      width: 100%;
      letter-spacing: 0.01em;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 8px 22px var(--accent-glow);
      transition: transform 120ms ease, box-shadow 120ms ease, background 120ms ease;
    }
    .btn:hover {
      background: var(--accent-strong);
      transform: translateY(-1px);
      box-shadow: 0 12px 26px var(--accent-glow);
    }
    .btn:active { transform: translateY(0); box-shadow: 0 6px 16px var(--accent-glow); }
    .btn svg { width: 18px; height: 18px; }

    .meta {
      text-align: center;
      color: var(--fg-muted);
      font-size: 14px;
      margin-bottom: 22px;
      word-break: break-word;
    }
  </style>
</head>
<body>
  <main>
    <section class="card">

      <% if (state === 'file') { %>
        <div class="icon-tile" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
          </svg>
        </div>
        <h1><%= itemName %></h1>
        <p class="meta"><%= t('file.meta') %></p>
        <a class="btn" href="/share/<%= encodeURIComponent(token) %>/download" download>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          <span><%= t('file.button') %></span>
        </a>

      <% } else if (state === 'password') { %>
        <div class="icon-tile" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
        </div>
        <h1><%= t('password.heading') %></h1>
        <p class="lead"><%= t('password.lead') %></p>
        <form method="post" action="/share/<%= encodeURIComponent(token) %>/auth" autocomplete="off" novalidate>
          <div>
            <label for="password"><%= t('password.label') %></label>
            <div class="input-wrap">
              <input
                type="password"
                id="password"
                name="password"
                required
                autofocus
                autocapitalize="off"
                autocorrect="off"
                spellcheck="false"
              />
              <button
                type="button"
                class="toggle-pw"
                data-toggle="password"
                data-shown="false"
                data-label-show="<%= t('password.show') %>"
                data-label-hide="<%= t('password.hide') %>"
                aria-label="<%= t('password.show') %>"
              >
                <svg class="eye-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
                <svg class="eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20c-7 0-11-8-11-8a19.77 19.77 0 0 1 4.22-5.94" />
                  <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a19.6 19.6 0 0 1-3.17 4.19" />
                  <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24" />
                  <line x1="1" y1="1" x2="23" y2="23" />
                </svg>
              </button>
            </div>
          </div>
          <% if (typeof error === 'string' && error) { %>
            <div class="error" role="alert">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
              </svg>
              <span><%= error %></span>
            </div>
          <% } %>
          <button type="submit" class="btn"><%= t('password.button') %></button>
        </form>

      <% } else if (state === 'expired') { %>
        <div class="icon-tile" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
        </div>
        <h1><%= t('expired.heading') %></h1>
        <p class="lead tight"><%= t('expired.body') %></p>

      <% } else { %>
        <div class="icon-tile" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
            <line x1="12" y1="9" x2="12" y2="13" />
            <line x1="12" y1="17" x2="12.01" y2="17" />
          </svg>
        </div>
        <h1><%= t('error.heading') %></h1>
        <p class="lead tight"><%= t('error.body') %></p>
        <% if (typeof upstreamStatus === 'number') { %>
          <p class="meta"><%= t('error.code') %>: <%= upstreamStatus %></p>
        <% } %>
      <% } %>

    </section>
  </main>

  <script>
    document.addEventListener("click", function (e) {
      var btn = e.target.closest('[data-toggle="password"]');
      if (!btn) return;
      var input = document.getElementById("password");
      if (!input) return;
      var shown = input.type === "text";
      input.type = shown ? "password" : "text";
      btn.setAttribute("data-shown", shown ? "false" : "true");
      btn.setAttribute(
        "aria-label",
        shown ? btn.dataset.labelShow : btn.dataset.labelHide
      );
    });
  </script>
</body>
</html>
